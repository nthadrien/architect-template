---
import Layout from "@layouts/Layout.astro";
import { available_languages } from "@locale/utils";
import type { GetStaticPaths } from "astro";

import IndexHeader from "@components/headers/IndexHeader.astro";
import Testimonials from "@components/sections/Testimonials.astro";
import Faq from "@components/sections/Faq.astro";
import Partners from "@components/sections/Partners.astro";
import ProjectCard from "@components/cards/ProjectCard.astro";
import BlogCard from "@components/cards/BlogCard.astro";

export const getStaticPaths = (() => {
    const locales = available_languages

    return locales.map( locale => ({
        params: { locale }
    }));
}) satisfies GetStaticPaths; 

const page_seo = {
	title: "Our services",
	description: "template",
	keywords: ["architect","template"],
    sidebar: false
}

const our_services  =  [
    { name : "Architectural Design",icon: "bi bi-buildings" , desc : "Comprehensive planning and design for new constructions."},
    { name : "Interior Architecture",icon: "bi bi-list" , desc : "Curating internal spaces that flow seamlessly with the exterior."},
    { name : "Interior Design",icon: "bi bi-intersect" , desc : "Curating internal spaces that flow seamlessly with the exterior."},
    { name : "Urban Planning",  icon: "bi bi-sign-intersection-side" , desc : "Large-scale development and community spatial planning."},
    { name : "Sustainable Consulting" ,icon: "bi bi-align-top" , desc : "LEED certification and eco-friendly material sourcing."}
];

---

<Layout {...page_seo}>

    <IndexHeader
        pgTitle={page_seo.title}
        center_text={true}
    />

    <main class="container row g-3 mx-auto my-5 py-5 px-2">

        {our_services.map( item => <div class="col-md-6 col-lg-4 d-flex gap-3 p-3">

            <i class={`display-3 text-primary ${item.icon}`} />

            <div>
                <h5 class="fw-bold">{item.name}</h5>
                <p>{item.desc}</p>
                <a class="text-primary" href="">Learn more <i class="ms-2 bi bi-arrow-right" /> </a>
            </div>

        </div>)}

    </main>


    <section class="container py-5 mx-auto my-5">

        <Testimonials />

    </section>
    
</Layout>
