---
import Testimonials from "@components/sections/Testimonials.astro";
import Partners from "@components/sections/Partners.astro";
import Team from "@components/sections/Team.astro";

import Layout from "@layouts/Layout.astro";
import { available_languages } from "@locale/utils";
import type { GetStaticPaths } from "astro";
import IndexHeader from "@components/headers/IndexHeader.astro";

export const getStaticPaths = (() => {
    const locales = available_languages

    return locales.map( locale => ({
        params: { locale }
    }));
}) satisfies GetStaticPaths; 

const page_seo = {
	title: "contact-us",
	description: "template",
	keywords: ["architect","template"]
}
---

<Layout {...page_seo}>

    <IndexHeader
        pgTitle={page_seo.title}
        text="We will love to hear from you"
        subtext={page_seo.description}
        center_text={true}
    />


    <section class="container row g-3 my-4 mx-auto py-5 align-items-center justify-content-between">

        <div class="col-md-8 section-header">
            <h2 class="fw-bold">Get in Touch</h2>
            <small class="display-2 fw-bold text-border">Contact US</small>
        </div>


        <aside class="col-12 col-md-5 p-3">
            
            <p class="mt-3 mb-5">
                Reach out to us if you have any inquiries or doubts or need
                to know more. We will 
                get to you as soon as possible 
            </p>

            <h5 class="fw-semibold mb-3">Contact Info</h5>

            <div class="row justify-content-between align-items-center g-2">
                    
                <i class="col-2 col-lg-1 bi bi-map fs-4 border-end"/>
                <p class="col-9 col-lg-11">
                    <strong>Addresses</strong><br/>
                    Yaounde, Mfouda, carefour
                </p>

                <i class="col-2 col-lg-1 bi bi-phone fs-4 border-end"/>
                <p class="col-9 col-lg-11">
                    <strong>Call</strong><br/>
                    (+237) 6XX-XXX-XXX
                </p>

                <i class="col-2 col-lg-1 bi bi-mailbox fs-4 border-end"/>
                <p class="col-9 col-lg-11">
                    <strong>Email US</strong><br/>
                    company.inc@gmail.com <br/>
                    Company.inc@mailbox.com
                </p>

            </div>

        </aside>


        <form class="col-12 col-md-6" action="">

            <div class="mb-3">
                <label for="exampleFormControlInput1" class="form-label">Name</label>
                <input type="email" class="form-control" id="exampleFormControlInput1" placeholder="name@example.com">
            </div>

            <div class="mb-3">
                <label for="exampleFormControlInput1" class="form-label">Your Contact</label>
                <input type="email" class="form-control" id="exampleFormControlInput1" placeholder="name@example.com">
            </div>

            <div class="form-floating mb-3">
                <input type="text" class="form-control" id="subject" name="subject" placeholder="Password">
                <label for="subject">Subject</label>
            </div>

            <div class="form-floating mb-3">
                <textarea class="form-control" placeholder="Leave a comment here" id="floatingTextarea2" style="height: 100px"></textarea>
                <label for="floatingTextarea2">Message</label>
            </div>


            <button type="submit" class="btn btn-lg btn-secondary">
                <i class="bi bi-send" /> Send Message
            </button>

        </form>

    </section>



    <section class="container-xl mx-auto rounded-3 overflow-auto">
        <iframe 
            width="100%"
            height="450" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade" 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d127395.73173775019!2d11.436382181513682!3d3.8277259253406394!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x108bcf7a309a7977%3A0x7f54bad35e0c1c51!2sYaound%C3%A9!5e0!3m2!1sen!2scm!4v1709295000000!5m2!1sen!2scm">
        </iframe>

    </section>
    

</Layout>