---
import Brand from "@components/Brand.astro";
import BaseFooter from "@components/footers/BaseFooter.astro";
---

<span class="d-md-none col-auto">
    <Brand />
</span>

<button class="navbar-toggler fs-3 border-0 col-auto" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasExample" aria-controls="offcanvasExample">
    <span class="navbar-toggler-icon"></span>
</button>

<div class=" d-md-none col-11 opacity-50 border-top" />
  
<section class="col-12 offcanvas offcanvas-start" tabindex="-1" id="offcanvasExample" aria-labelledby="offcanvasExampleLabel">

    <div class="offcanvas-header border-0">
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>

    <div style="min-height: 95vh;" class="offcanvas-body d-flex gap-1 sticky-top top-25">

        <aside style="width: 2.2rem;" class="d-flex flex-column gap-3 align-items-center justify-content-center small">
            <span class="mt-3 text-vertical"> ANY INSPIRED TEXT </span>
            <span class="vr mx-auto" />

            <a href="#">
                <i class="bi bi-facebook" />
            </a>
        
            <a class="" href="#">
                <i class="bi bi-whatsapp" />
            </a>
            
            <a class="" href="#">
                <i class="bi bi-telegram" />
            </a>
            
            <a class="" href="#">
                <i class="bi bi-instagram" />
            </a>
        </aside>


        <div class="d-flex flex-column gap-2 mh-50 p-2">

            <div class="mt-3 mb-5 d-flex justify-content-between align-items-center">
                <Brand />
            </div>

            <a href="/#" class="nav-item">Home</a>
            <a href="/en/about-us" class="nav-item">About US</a>
            <a href="/en/about-us" class="nav-item">Services</a>
            <a href="/en/about-us#testimonials" class="nav-item">Testimonials</a>
            <a href="/en/projects" class="nav-item">Projects</a>
            <a href="/en/blog" class="nav-item">Blog </a>
            <a href="/en/contact-us" class="nav-item">Contact US</a>


            <div class="small mt-auto"> 
                <BaseFooter />
            </div>

        </div>

        
      
    </div>

</section>