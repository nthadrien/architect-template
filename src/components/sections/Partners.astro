---
const partners_list = [
  {
    name: "Google",
    logo: "/logos/google.svg",
    url: "https://www.google.com",
  },
  {
    name: "Microsoft",
    logo: "data:image/jpeg;base64,",
    url: "https://www.microsoft.com",
  },
  {
    name: "Amazon",
    logo: "/logos/amazon.svg",
    url: "https://www.amazon.com",
  },
  {
    name: "Meta",
    logo: "/logos/meta.svg",
    url: "https://www.meta.com",
  },
  {
    name: "Apple",
    logo: "/logos/apple.svg",
    url: "https://www.apple.com",
  },
  {
    name: "Netflix",
    logo: "/logos/netflix.svg",
    url: "https://www.netflix.com",
  },
  {
    name: "Spotify",
    logo: "/logos/spotify.svg",
    url: "https://www.spotify.com",
  },
  {
    name: "Adobe",
    logo: "/logos/adobe.svg",
    url: "https://www.adobe.com",
  },
  {
    name: "Shopify",
    logo: "/logos/shopify.svg",
    url: "https://www.shopify.com",
  },
  {
    name: "Stripe",
    logo: "/logos/stripe.svg",
    url: "https://www.stripe.com",
  },
];

const leno = partners_list.length;
---

<section class="container mx-auto my-4 py-4">
  <h3 class="fw-bold mb-4 text-end">Trusted Partners</h3>

  <div class="overflow-x-auto hide-scrollbar my-4">
    <div id="slider" class="d-flex py-4" id="track">
      <!-- Original Items -->
      {
        partners_list.map((item) => (
          <a
            href={item.url}
            style="min-width: 148px;"
            class="d-flex flex-column justify-content-evenly align-items-center flex-shrink-0"
          >
            <img
              src="https://via.placeholder.com/200x80?text=Partner+1"
              alt="Partner 1"
            />
            <strong>{item.name}</strong>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style define:vars={{ leno }}>
  #slider {
    animation: sliding-it 17s ease-in 1s infinite forwards;
  }

  #slider:hover {
    animation-play-state: paused;
  }

  #slider img {
    max-width: 100%;
    max-height: 100%;
    filter: grayscale(100%);
    opacity: 0.7;
    transition: all 0.3s ease;
  }

  #slider a:hover {
    filter: grayscale(0%);
    opacity: 1;
    transform: scale(1.5);
    transition: all 0.4s ease;
  }

  @keyframes sliding-it {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(calc(var(--leno) * -65px));
    }
  }
</style>
