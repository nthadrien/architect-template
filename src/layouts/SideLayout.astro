---
import { getLocaleFromUrl } from '@locale/utils';
import Breadcrumb from "@components/tools/Breadcrumb.astro";
import SideNavbar from '@components/navbars/SideNavbar.astro';
import Brand from '@components/Brand.astro';

const locale = getLocaleFromUrl(Astro.url);

interface Props {
	title: string;
	description: string;
	keywords: string[];
	sidebar?: boolean;
}
const {
	title, 
	description, 
	keywords,
	sidebar = true
} = Astro.props;
---

<!doctype html>
<html lang={locale}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/logo.png" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords.toLocaleString()} />
		<title> {title} | template </title>
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
	</head>

	<body style="max-width: 1860px;" class="container-fluid mx-auto row justify-content-center justify-content-md-between p-0" data-bs-theme="auto">

        <nav class="col-md-2 navbar align-items-md-start navbar-expand-md p-3 p-md-2 shadow-md">
			<div class="sticky-top top-0 nav justify-content-between align-items-center w-100 gap-3">
				<SideNavbar />
			</div>
        </nav>

		<main class={`col-md-${sidebar? "8":"9"} pt-5 px-1`}>

			<header class="nav p-2">
				<Breadcrumb />
			</header>

			<section class="w-100 mx-auto p-2">
                <slot />
            </section>

		</main>

		<aside class={`col-11 col-md-${sidebar? "2":"1"} pt-5 px-1`}>
			<div class="sticky-top top-0">
				<slot name="side-section" />
			</div>
		</aside>

	</body>

	<script 
		src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" 
		integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" 
		crossorigin="anonymous">
	</script>

</html>

<style is:global>

	:root {
		font-size: 10px;
		font-family:'Times New Roman', Times, serif;
	}
	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	html,
	body {
		width: 100%;
		height: 100%;
	}

	a , .nav-item {
		color: inherit;
		text-decoration: none ;

		&:hover {
			font-weight: bold;
		}
	}

	.text-xs {
		font-size: xx-small;
	}

	.text-sm {
		font-size: x-small;
	}

	.text-md {
		font-size: smaller;
	}

	details {
		appearance: none;
		max-height: 4rem;
		transition: all 2s ease-in-out;

		summary {
			position: relative;
			list-style: none;
		}
		summary::-webkit-details-marker {
			display: none;
		}

		summary::after {
			content: "-";
			position: absolute;
			right: 1rem;
		}

		summary + p {
			max-height: 0;
			overflow: hidden;
			transition: all 1s ease-in-out;
		}

		&:open { 

			max-height: 50vh;

			summary + p  {
				max-height: 580px;
				transition: all 1s ease-in-out;
			}

			summary {
				background-color: rgba(211, 211, 211, 0.625);
			}

			summary::after {
				content: "+";
			}
		}
	}

	/* Hide scrollbar for Chrome, Safari and Opera */
	.hide-scrollbar::-webkit-scrollbar {
		display: none;
	}

	/* Hide scrollbar for IE, Edge and Firefox */
	.hide-scrollbar {
		-ms-overflow-style: none;  /* IE and Edge */
		scrollbar-width: none;  /* Firefox */
	}

	/* hover show */

	.hoverable {
		.hover-show {
			opacity: 0;
			overflow: hidden;
			transition: all 1s linear;
		}

		&:hover {
			.hover-show {
				opacity: 1;
			}
		}
	}

	.section-header {
		position: relative;

		h2 {
			z-index: 2;
		}

		small {
			position: absolute;
			z-index: 1;
			top: 50%;
			transform: translateY(-50%);
			color: transparent;
			left: 0;
		}
	}

	.text-border {
		-webkit-text-stroke-width: 2px;
		-webkit-text-stroke-color: rgba(174, 164, 164, 0.321);
    }

   .text-vertical {
		writing-mode: vertical-lr;
		text-orientation: mixed;
   	}

	.text-justify {
		text-justify:distribute;
        text-align: justify;
	}

	@media (min-width: 1096px) {
		:root {
			font-size: 12px;
		}
	}

	@media (min-width: 1800px) {
		:root {
			font-size: 1rem;
		}
	}

	.pj-card {

		cursor: pointer;
		overflow: hidden;

		img {
			transition: all .2s ease;
		}

		.hide {
			opacity: 0;
			transition: all 0.3s linear;

			* {
				transform: translateY(55px);
			}
		}


		&:hover {

			img {
				transform: scale(1.09);
			}

			.hide {
				opacity: 1;

				* {
					transform: translateY(0);
				}
			}
		}


	}
        
</style>
