---
import Navbar from "@components/navbars/Navbar.astro";
import Footer from "@components/footers/Footer.astro";
import { getLocaleFromUrl } from '@locale/utils';

const locale = getLocaleFromUrl(Astro.url);

interface Props {
	title: string;
	description: string;
	keywords: string[]
}
const {
	title, 
	description, 
	keywords
} = Astro.props;
---

<!doctype html>
<html lang={locale}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords.toLocaleString()} />
		<title> {title} | template </title>
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
	</head>
	<body class="posiition-relative" data-bs-theme="auto">
		<Navbar />
		<slot />
		<Footer />
	</body>
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
	<script src="https://cdn.jsdelivr.net/npm/masonry-layout@4.2.2/dist/masonry.pkgd.min.js" integrity="sha384-GNFwBvfVxBkLMJpYMOABq3c+d3KnQxudP/mGPkzpZSTYykLBNsZEnG2D9G/X/+7D" crossorigin="anonymous" async></script>
</html>

<style is:global>

@import url('https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&family=Roboto:ital,wght@0,100..900;1,100..900&family=Urbanist:ital@0;1&display=swap');
	:root {
		font-family: 'Montserrat', sans-serif;
		/* font-size: 15px; */
		--bs-primary-clr: #2a3e55;
		--bs-primary: #2a3e55;
		--bs-primary-rgb: #2a3e55;
	}
	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
		transition: all .24s linear;
	}

	html,
	body {
		width: 100%;
		height: 100%;
	}

	a , .nav-item {
		color: inherit;
		text-decoration: none ;
		cursor: pointer;
	}

	.text-xs {
		font-size: xx-small;
	}

	.text-sm {
		font-size: x-small;
	}

	.text-md {
		font-size: smaller;
	}

	details {
		appearance: none;
		transition: all 2s ease-in-out;

		summary {
			position: relative;
			list-style: none;
		}

		summary::-webkit-details-marker {
			display: none;
		}

		summary::after {
			content: "-";
			position: absolute;
			right: 1rem;
		}

		summary + p {
			max-height: 0;
			overflow: hidden;
			transition: all 1s ease-in-out;
		}

		&:open { 

			summary + p  {
				max-height: 580px;
				transition: all 1s ease-in-out;
			}

			summary {
				color: var(--bs-primary);
				/* background-color: rgba(211, 211, 211, 0.625); */
			}

			summary::after {
				content: "+";
			}
		}
	}

	/* Hide scrollbar for Chrome, Safari and Opera */
	.hide-scrollbar::-webkit-scrollbar {
		display: none;
	}

	/* Hide scrollbar for IE, Edge and Firefox */
	.hide-scrollbar {
		-ms-overflow-style: none;  /* IE and Edge */
		scrollbar-width: none;  /* Firefox */
	}

	/* hover show */

	.hoverable {
		.hover-show {
			opacity: 0;
			overflow: hidden;
			transition: all 1s linear;
		}

		&:hover {
			.hover-show {
				opacity: 1;
			}
		}
	}

	.section-header {
		position: relative;

		h2 {
			z-index: 2;
		}

		small {
			position: absolute;
			z-index: 1;
			top: 50%;
			transform: translateY(-50%);
			color: transparent;
			left: 0;
		}
	}

	.text-border {
		-webkit-text-stroke-width: 2px;
		-webkit-text-stroke-color: rgba(0, 0, 0, 0.214);
    }
        
	.text-justify {
		text-justify:distribute;
        text-align: justify;
	}

    .pj-card {

        cursor: pointer;
        overflow: hidden;

        img {
            transition: all .2s ease;
        }

        .hide {
            opacity: 0;
            transition: all 0.3s linear;

            * {
                transform: translateY(55px);
            }
        }


        &:hover {

            img {
                transform: scale(1.09);
            }

            .hide {
                opacity: 1;

                & >* {
                    transform: translateY(0);
                }
            }
        }


    }
</style>